# Set to "true" to enable /dev/advance and /dev/back endpoints for testing.
# NEVER set this in production — it allows bypassing stage order.
DEV_OVERRIDE=false

# 4-digit codes printed on physical cards at each stage location.
# If set, these override the auto-generated codes in stages.json.
# Leave unset to use whatever is in stages.json (auto-generated on first run).
STAGE_1_CODE=
STAGE_2_CODE=
STAGE_3_CODE=
STAGE_4_CODE=
STAGE_5_CODE=
